{
  "name": "md-budget-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run validate:data",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dashboard:install": "cd dashboard && npm install",
    "dashboard:build": "cd dashboard && npm run build",
    "dashboard:dev": "cd dashboard && npm run dev",
    "ingest": "node data/warehouse/ingest.mjs",
    "ingest:counties": "node data/warehouse/ingest-counties.mjs",
    "ingest:opendata": "node data/warehouse/ingest-opendata.mjs",
    "ingest:stateaid": "node data/warehouse/ingest-stateaid.mjs",
    "ingest:chas": "node data/warehouse/ingest-chas.mjs",
    "ingest:all": "npm run ingest:counties && npm run ingest:opendata && npm run ingest:stateaid && npm run ingest:chas && npm run bundle:map",
    "bundle:map": "node data/warehouse/bundle.mjs",
    "expand:templates": "node data/warehouse/expand-templates.mjs",
    "validate:data": "node data/warehouse/validate.mjs"
  },
  "dependencies": {
    "@types/topojson-client": "^3.1.5",
    "d3": "^7.9.0",
    "next": "16.2.4",
    "plotly.js": "^3.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-plotly.js": "^2.6.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/d3": "^7.4.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-plotly.js": "^2.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
